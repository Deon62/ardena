    { "source": "/car-rental-mombasa", "destination": "/car-rental-mombasa.html" },
    { "source": "/car-rental-mombasa/", "destination": "/car-rental-mombasa.html" },
    { "source": "/car-rental-kisumu", "destination": "/car-rental-kisumu.html" },
    { "source": "/car-rental-kisumu/", "destination": "/car-rental-kisumu.html" },
    { "source": "/car-rental-nakuru", "destination": "/car-rental-nakuru.html" },
